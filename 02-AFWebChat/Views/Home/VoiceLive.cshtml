@{
    ViewData["Title"] = "VoiceLive (speech-to-speech)";
    Layout = "_Layout";
}

<style>
    .vl-wrap { max-width: 1100px; margin: 24px auto; padding: 0 16px; }
    .vl-card { background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 24px; color: #e6edf3; }
    .vl-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
    .vl-header h2 { margin: 0; }
    .vl-status { font-size: 0.9rem; padding: 4px 10px; border-radius: 999px; background: #30363d; }
    .vl-status.connected { background: #238636; }
    .vl-status.error { background: #f85149; }
    .vl-controls { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; }
    .vl-controls button { padding: 10px 18px; border-radius: 8px; border: 1px solid #30363d; background: #21262d; color: #e6edf3; cursor: pointer; font-size: 0.95rem; }
    .vl-controls button:hover:not(:disabled) { background: #30363d; }
    .vl-controls button:disabled { opacity: 0.5; cursor: not-allowed; }
    .vl-controls .primary { background: #238636; border-color: #238636; }
    .vl-controls .danger { background: #da3633; border-color: #da3633; }
    .vl-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    .vl-panel { background: #0d1117; border: 1px solid #30363d; border-radius: 8px; padding: 14px; }
    .vl-panel h4 { margin: 0 0 8px; color: #58a6ff; font-size: 0.95rem; }
    .vl-events, .vl-transcript { height: 240px; overflow-y: auto; font-family: ui-monospace, Menlo, monospace; font-size: 0.85rem; white-space: pre-wrap; }
    .vl-events div { padding: 2px 0; }
    .vl-events .ev-error { color: #f85149; }
    .vl-events .ev-info { color: #8b949e; }
    .vl-events .ev-speech { color: #d29922; }
    .vl-events .ev-response { color: #58a6ff; }
    .vl-meter { height: 8px; background: #30363d; border-radius: 4px; overflow: hidden; margin-top: 12px; }
    .vl-meter > div { height: 100%; width: 0%; background: linear-gradient(90deg, #238636, #d29922, #f85149); transition: width 80ms linear; }
    .vl-config { display: grid; grid-template-columns: 1fr; gap: 10px; margin-bottom: 18px; }
    .vl-config label { font-size: 0.85rem; color: #8b949e; }
    .vl-config input, .vl-config textarea, .vl-config select { width: 100%; padding: 8px 10px; background: #0d1117; border: 1px solid #30363d; border-radius: 6px; color: #e6edf3; }
    .vl-config select { appearance: none; -webkit-appearance: none; background-image: linear-gradient(45deg, transparent 50%, #8b949e 50%), linear-gradient(135deg, #8b949e 50%, transparent 50%); background-position: calc(100% - 16px) 50%, calc(100% - 11px) 50%; background-size: 5px 5px; background-repeat: no-repeat; padding-right: 28px; }
    .vl-config select optgroup { font-weight: 600; color: #58a6ff; }
    .vl-config select option { background: #0d1117; color: #e6edf3; }
    .vl-config textarea { min-height: 70px; resize: vertical; font-family: inherit; }
    .vl-avatar-config { border: 1px dashed #30363d; border-radius: 8px; padding: 10px 12px; margin-top: 4px; background: #0d1117; }
    .vl-avatar-toggle { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
    .vl-switch { display: flex; align-items: center; gap: 8px; cursor: pointer; user-select: none; font-size: 0.95rem; }
    .vl-switch input { width: auto; }
    .vl-avatar-link { color: #58a6ff; font-size: 0.85rem; text-decoration: none; }
    .vl-avatar-link:hover { text-decoration: underline; }
    .vl-avatar-stage { display: none; margin-top: 18px; padding: 14px; background: #0d1117; border: 1px solid #30363d; border-radius: 8px; align-items: center; gap: 14px; }
    .vl-avatar-stage.active { display: flex; }
    .vl-avatar-video { width: 360px; height: 360px; border-radius: 12px; background: #000; object-fit: cover; flex-shrink: 0; box-shadow: 0 4px 16px rgba(0,0,0,0.5); }
    .vl-avatar-info { flex: 1; }
    .vl-avatar-info h5 { margin: 0 0 4px; }
    .vl-avatar-info small { color: #8b949e; }
    .vl-viseme-bar { height: 6px; background: #21262d; border-radius: 3px; overflow: hidden; margin-top: 8px; }
    .vl-viseme-bar > div { height: 100%; width: 0; background: linear-gradient(90deg, #58a6ff, #d29922); transition: width 60ms linear; }
    .vl-text-input { display: flex; gap: 8px; margin-top: 10px; }
    .vl-text-input input { flex: 1; padding: 8px 10px; background: #0d1117; border: 1px solid #30363d; border-radius: 6px; color: #e6edf3; }
</style>

<div class="vl-wrap">
    <div class="vl-card">
        <div class="vl-header">
            <h2><i class="bi bi-broadcast me-2"></i>VoiceLive — Speech-to-Speech</h2>
            <span id="vlStatus" class="vl-status">Desconectado</span>
        </div>

        <div class="vl-config">
            <div>
                <label for="vlInstructions">Instrucciones del sistema</label>
                <textarea id="vlInstructions" placeholder="Eres un asistente útil..."></textarea>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                <div>
                    <label for="vlVoice">Voz (catálogo)</label>
                    <select id="vlVoice" class="vl-select"></select>
                </div>
                <div>
                    <label for="vlModel">Modelo</label>
                    <input id="vlModel" type="text" placeholder="gpt-4o-mini-realtime-preview" disabled />
                </div>
            </div>

            <div id="vlStyleRow" style="display: none;">
                <label for="vlStyle">Estilo / expresión</label>
                <select id="vlStyle" class="vl-select"></select>
            </div>

            <div class="vl-avatar-config">
                <div class="vl-avatar-toggle">
                    <label class="vl-switch">
                        <input type="checkbox" id="vlAvatarEnabled" />
                        <span>🎭 Habilitar Avatar (video real-time vía WebRTC)</span>
                    </label>
                    <span class="vl-avatar-link" id="vlAvatarStatus">WebRTC: desconectado</span>
                </div>
                <div id="vlAvatarFields" style="display: none; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 8px;">
                    <div>
                        <label for="vlAvatarCharacter">Personaje</label>
                        <select id="vlAvatarCharacter" class="vl-select"></select>
                    </div>
                    <div>
                        <label for="vlAvatarStyle">Estilo del personaje</label>
                        <select id="vlAvatarStyle" class="vl-select"></select>
                    </div>
                </div>
            </div>
        </div>

        <div class="vl-controls">
            <button id="vlConnect" class="primary"><i class="bi bi-plug"></i> Conectar</button>
            <button id="vlDisconnect" disabled><i class="bi bi-x-circle"></i> Desconectar</button>
            <button id="vlMic" disabled><i class="bi bi-mic"></i> Activar micrófono</button>
            <button id="vlStop" class="danger" disabled><i class="bi bi-stop-circle"></i> Interrumpir</button>
        </div>

        <div class="vl-meter"><div id="vlMeter"></div></div>

        <div id="vlAvatarStage" class="vl-avatar-stage">
            <video id="vlAvatarVideo" class="vl-avatar-video" autoplay playsinline muted></video>
            <div class="vl-avatar-info">
                <h5 id="vlAvatarName">Avatar</h5>
                <small id="vlAvatarDetails">Esperando WebRTC…</small>
                <div class="vl-viseme-bar"><div id="vlVisemeBar"></div></div>
            </div>
        </div>

        <div class="vl-grid" style="margin-top: 18px;">
            <div class="vl-panel">
                <h4><i class="bi bi-chat-dots"></i> Transcripción</h4>
                <div id="vlTranscript" class="vl-transcript"></div>
                <div class="vl-text-input">
                    <input id="vlTextInput" type="text" placeholder="Escribe un mensaje y Enter..." disabled />
                    <button id="vlSendText" disabled>Enviar</button>
                </div>
            </div>
            <div class="vl-panel">
                <h4><i class="bi bi-activity"></i> Eventos</h4>
                <div id="vlEvents" class="vl-events"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/voice-live.js" asp-append-version="true"></script>
}
