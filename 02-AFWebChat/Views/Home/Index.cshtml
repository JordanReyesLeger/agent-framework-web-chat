@using Microsoft.Extensions.Options
@using AFWebChat.Models
@inject IOptions<AppBrandingSettings> BrandingOptions
@{
    ViewData["Title"] = "Home";
    var branding = BrandingOptions.Value;
}

<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />

<div class="index-page">
    <!-- Animated Background Shapes -->
    <div class="animated-background">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <div class="hero-section">
        <div class="hero-content">
            <div class="hero-icon">
                @if (!string.IsNullOrEmpty(branding.LogoUrl))
                {
                    <img src="@branding.LogoUrl" alt="@branding.Title" />
                }
                else
                {
                    <i class="bi @branding.LogoIcon"></i>
                }
            </div>
            <h1 class="display-4 hero-title">@branding.Subtitle</h1>
            <p class="lead hero-subtitle">
                @branding.WelcomeMessage
            </p>
            <div class="hero-cta">
                <a asp-controller="Home" asp-action="Chat" class="btn btn-primary btn-lg">
                    <i class="bi bi-chat-dots me-2"></i> Comenzar a Chatear
                </a>
            </div>
        </div>
    </div>

    <section class="cfe-arch">
        <div class="cfe-arch-head">
            <span class="cfe-arch-eyebrow"><i class="bi bi-diagram-3"></i> Arquitectura de la solución</span>
            <h2 class="cfe-arch-title">De la interacción a la <span>automatización inteligente</span></h2>
            <p class="cfe-arch-sub">
                Plataforma de agentes de IA para la mesa de servicio y la ciberseguridad de CFE — cinco capas que evolucionan del avatar a la autonomía.
            </p>
        </div>

        <div class="cfe-stack">

            <article class="cfe-layer cfe-l1" style="--i:0">
                <div class="cfe-layer-label">
                    <span class="cfe-layer-tag">Capa 1</span>
                    <h3>Experiencia de Usuario</h3>
                    <p>Interacción natural en los canales de preferencia</p>
                </div>
                <div class="cfe-layer-body">
                    <div class="cfe-group">
                        <span class="cfe-group-title">Usuarios</span>
                        <div class="cfe-chips">
                            <span class="cfe-chip"><i class="bi bi-person"></i> Empleados</span>
                            <span class="cfe-chip"><i class="bi bi-hdd-network"></i> Operadores de Red</span>
                            <span class="cfe-chip"><i class="bi bi-shield-lock"></i> Personal de Seguridad</span>
                            <span class="cfe-chip"><i class="bi bi-person-badge"></i> Directivos</span>
                        </div>
                    </div>
                    <div class="cfe-group">
                        <span class="cfe-group-title">Canales</span>
                        <div class="cfe-chips">
                            <span class="cfe-chip"><i class="bi bi-window-desktop"></i> Portal CFE</span>
                            <span class="cfe-chip"><i class="bi bi-chat-square-text"></i> Microsoft Teams</span>
                            <span class="cfe-chip"><i class="bi bi-phone"></i> App Móvil</span>
                            <span class="cfe-chip"><i class="bi bi-telephone"></i> Voz / Telefonía</span>
                            <span class="cfe-chip cfe-chip--star"><i class="bi bi-person-video3"></i> Avatar Digital</span>
                        </div>
                    </div>
                </div>
            </article>

            <div class="cfe-flow"><span></span></div>

            <article class="cfe-layer cfe-l2" style="--i:1">
                <div class="cfe-layer-label">
                    <span class="cfe-layer-tag">Capa 2</span>
                    <h3>Orquestador de IA</h3>
                    <p>Entiende, decide y orquesta la mejor acción</p>
                </div>
                <div class="cfe-layer-body">
                    <div class="cfe-orb">
                        <span class="cfe-orb-icon">🧠</span>
                        <div class="cfe-orb-txt">
                            <strong>Avatar Inteligente CFE</strong>
                            <small>Comprende solicitudes en lenguaje natural</small>
                        </div>
                    </div>
                    <div class="cfe-group cfe-group--grow">
                        <span class="cfe-group-title">Agentes especializados</span>
                        <div class="cfe-agents">
                            <span class="cfe-agent" style="--c:#00a86b">🎧 Mesa de Ayuda</span>
                            <span class="cfe-agent" style="--c:#ae8420">🔑 Identidad</span>
                            <span class="cfe-agent" style="--c:#0f9488">🖥️ Infraestructura</span>
                            <span class="cfe-agent" style="--c:#a8324f">🛡️ Seguridad</span>
                            <span class="cfe-agent" style="--c:#4b7d3a">📋 Cumplimiento</span>
                            <span class="cfe-agent" style="--c:#0aa06a">📊 Ejecutivo</span>
                        </div>
                    </div>
                </div>
            </article>

            <div class="cfe-flow"><span></span></div>

            <article class="cfe-layer cfe-l3" style="--i:2">
                <div class="cfe-layer-label">
                    <span class="cfe-layer-tag">Capa 3</span>
                    <h3>Integración Empresarial</h3>
                    <p>Conecta con los sistemas críticos de CFE</p>
                </div>
                <div class="cfe-layer-body cfe-sys">
                    <div class="cfe-sys-card"><span class="cfe-sys-h"><i class="bi bi-kanban"></i> ITSM</span><em>ServiceNow · BMC · Remedy</em></div>
                    <div class="cfe-sys-card"><span class="cfe-sys-h"><i class="bi bi-fingerprint"></i> Identidad</span><em>Entra ID · Active Directory · PAM</em></div>
                    <div class="cfe-sys-card"><span class="cfe-sys-h"><i class="bi bi-hdd-rack"></i> Infraestructura</span><em>CMDB · Inventario TI · Monitoreo</em></div>
                    <div class="cfe-sys-card"><span class="cfe-sys-h"><i class="bi bi-shield-shaded"></i> Seguridad</span><em>SIEM · EDR/XDR · SOC</em></div>
                    <div class="cfe-sys-card"><span class="cfe-sys-h"><i class="bi bi-journal-text"></i> Conocimiento</span><em>Procedimientos · Políticas · Tickets</em></div>
                </div>
            </article>

            <div class="cfe-flow"><span></span></div>

            <article class="cfe-layer cfe-l4" style="--i:3">
                <div class="cfe-layer-label">
                    <span class="cfe-layer-tag">Capa 4</span>
                    <h3>Automatización Inteligente</h3>
                    <p>De la asistencia a la autonomía</p>
                </div>
                <div class="cfe-layer-body cfe-levels">
                    <div class="cfe-level">
                        <span class="cfe-level-n">Nivel 1</span><strong>Asistencia</strong>
                        <em>Consulta documental · FAQ · Estado de tickets</em>
                    </div>
                    <div class="cfe-level-arrow"><i class="bi bi-arrow-right"></i></div>
                    <div class="cfe-level">
                        <span class="cfe-level-n">Nivel 2</span><strong>Ejecución</strong>
                        <em>Crear/asignar tickets · Restablecer accesos</em>
                    </div>
                    <div class="cfe-level-arrow"><i class="bi bi-arrow-right"></i></div>
                    <div class="cfe-level cfe-level--peak">
                        <span class="cfe-level-n">Nivel 3</span><strong>Autonomía</strong>
                        <em>Correlación · Causa raíz · Remediación automática</em>
                    </div>
                </div>
            </article>

            <div class="cfe-flow"><span></span></div>

            <article class="cfe-layer cfe-l5" style="--i:4">
                <div class="cfe-layer-label">
                    <span class="cfe-layer-tag">Capa 5</span>
                    <h3>Valor para el CISO</h3>
                    <p>Impacto directo en seguridad, operación y gobierno</p>
                </div>
                <div class="cfe-layer-body cfe-value">
                    <div class="cfe-pillar">
                        <i class="bi bi-shield-check"></i><strong>Seguridad</strong>
                        <em>Políticas consistentes · Auditoría · Menor error humano</em>
                    </div>
                    <div class="cfe-pillar">
                        <i class="bi bi-lightning-charge"></i><strong>Operación</strong>
                        <em>Atención 24×7 · Resolución acelerada · Menor carga</em>
                    </div>
                    <div class="cfe-pillar">
                        <i class="bi bi-graph-up-arrow"></i><strong>Gobierno</strong>
                        <em>KPIs en tiempo real · Tendencias · Gestión de riesgos</em>
                    </div>
                    <div class="cfe-value-brand">CFE · <span>Somos más que energía</span></div>
                </div>
            </article>

        </div>
    </section>
</div>
