@{
    ViewData["Title"] = "Agente de Voz";
}
@using Microsoft.Extensions.Options
@using AFWebChat.Models
@inject IOptions<AppBrandingSettings> BrandingOptions
@{
    var branding = BrandingOptions.Value;
}

<link rel="stylesheet" href="~/css/voice-agent.css" asp-append-version="true" />

<div class="voice-page-wrapper"
     data-primary-color="@branding.PrimaryColor"
     data-accent-color="@branding.AccentColor"
     data-background-color="@branding.BackgroundColor"
     data-text-color="@branding.TextColor"
     data-success-color="@branding.SuccessColor"
     data-error-color="@branding.ErrorColor">

    <!-- Animated Background -->
    <div class="animated-background">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <!-- Main Voice Interface -->
    <div class="voice-container">
        <!-- Status Bar -->
        <div class="voice-status-bar">
            <div class="voice-status-indicator" id="statusIndicator">
                <span class="status-dot"></span>
                <span class="status-text" id="statusText">Listo para comenzar</span>
            </div>
            <div class="voice-controls-top">
                <button class="voice-btn-icon" id="btnTranscript" title="Ver transcripción">
                    <i class="bi bi-journal-text"></i>
                </button>
                <button class="voice-btn-icon" id="btnSettings" title="Configuración">
                    <i class="bi bi-gear"></i>
                </button>
                <button class="voice-btn-icon" id="btnNewSession" title="Nueva sesión">
                    <i class="bi bi-plus-circle"></i>
                </button>
            </div>
        </div>

        <!-- Orb Container -->
        <div class="orb-section">
            <div class="orb-container" id="orbContainer">
                <canvas id="orbCanvas" width="400" height="400"></canvas>
                <div class="orb-glow" id="orbGlow"></div>
            </div>
            <!-- Live captions -->
            <div class="live-caption-area">
                <div class="live-caption" id="liveCaption"></div>
            </div>
        </div>

        <!-- Current Response Text -->
        <div class="response-area" id="responseArea">
            <div class="response-text" id="responseText"></div>
        </div>

        <!-- Main Control -->
        <div class="voice-main-controls">
            <button class="voice-start-btn" id="btnStartVoice" title="Mantener presionado para hablar">
                <i class="bi bi-mic-fill"></i>
            </button>
            <button class="voice-stop-btn hidden" id="btnStopVoice" title="Detener">
                <i class="bi bi-stop-fill"></i>
            </button>
        </div>

        <!-- Bottom Info -->
        <div class="voice-footer-info">
            <span id="sessionInfo">Sesión no iniciada</span>
        </div>
    </div>

    <!-- Transcript Sidebar -->
    <div class="transcript-sidebar" id="transcriptSidebar">
        <div class="transcript-header">
            <h6><i class="bi bi-journal-text me-2"></i>Transcripción</h6>
            <button class="voice-btn-icon" id="btnCloseTranscript">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="transcript-body" id="transcriptBody">
            <div class="transcript-empty">
                <i class="bi bi-chat-left-text" style="font-size: 2rem; opacity: 0.3;"></i>
                <p>La transcripción aparecerá aquí cuando inicies una conversación.</p>
            </div>
        </div>
        <div class="transcript-footer">
            <button class="btn btn-sm btn-outline-light" id="btnExportTranscript">
                <i class="bi bi-download me-1"></i>Exportar
            </button>
        </div>
    </div>

    <!-- Settings Modal -->
    <div class="settings-overlay hidden" id="settingsOverlay">
        <div class="settings-panel">
            <div class="settings-header">
                <h6><i class="bi bi-gear me-2"></i>Configuración de Voz</h6>
                <button class="voice-btn-icon" id="btnCloseSettings">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="settings-body">
                <div class="setting-group">
                    <label>Prompt del Sistema</label>
                    <textarea id="systemPrompt" rows="3" class="form-control form-control-sm" 
                              placeholder="Instrucciones para el agente...">Eres un asistente de IA amigable y conversacional. Responde de forma concisa y natural, como si estuvieras hablando en una conversación real. Mantén tus respuestas breves (2-3 oraciones máximo) a menos que el usuario pida una explicación detallada.</textarea>
                </div>
                <div class="setting-group">
                    <label>Velocidad de Voz</label>
                    <input type="range" id="speechRate" min="0.5" max="2.0" step="0.1" value="1.0" class="form-range" />
                    <span id="speechRateValue">1.0x</span>
                </div>
                <div class="setting-group">
                    <label>
                        <input type="checkbox" id="autoContinue" checked /> Escucha continua
                    </label>
                    <small>Sigue escuchando después de que el agente responda</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Azure Speech SDK -->
    <script src="https://aka.ms/csspeech/jsbrowserpackageraw"></script>
    <!-- Voice Agent Logic -->
    <script src="~/js/voice-agent.js" asp-append-version="true"></script>
}
