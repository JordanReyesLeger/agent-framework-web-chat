{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.22/MicrosoftTeams.schema.json",
  "manifestVersion": "1.22",
  "version": "1.0.2",
  "id": "<<AAD_APP_CLIENT_ID>>",
  "developer": {
    "name": "AF-WebChat",
    "websiteUrl": "https://<<BOT_DOMAIN>>",
    "privacyUrl": "https://<<BOT_DOMAIN>>/privacy",
    "termsOfUseUrl": "https://<<BOT_DOMAIN>>/termsofuse"
  },
  "name": {
    "short": "AF-WebChat",
    "full": "AF-WebChat Multi-Agent Assistant"
  },
  "description": {
    "short": "Multi-agent AI assistant powered by Microsoft Agent Framework",
    "full": "AF-WebChat is a multi-agent AI assistant with specialized agents for SQL, Legal, INEGI, Code Review and more. Switch between agents using /agent commands or chat naturally."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#C9A227",
  "webApplicationInfo": {
    "id": "<<AAD_APP_CLIENT_ID>>",
    "resource": "api://example.com"
  },
  "bots": [
    {
      "botId": "<<AAD_APP_CLIENT_ID>>",
      "scopes": ["personal", "team", "groupChat", "copilot"],
      "supportsFiles": true,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal"],
          "commands": [
            {
              "title": "agents",
              "description": "List all available AI agents"
            },
            {
              "title": "agent",
              "description": "Switch to a specific agent"
            },
            {
              "title": "clear",
              "description": "Clear chat history"
            },
            {
              "title": "new",
              "description": "Start a fresh conversation"
            },
            {
              "title": "help",
              "description": "Show available commands"
            }
          ]
        }
      ]
    }
  ],
  "copilotAgents": {
    "customEngineAgents": [
      {
        "id": "<<AAD_APP_CLIENT_ID>>",
        "type": "bot",
        "disclaimer": {
          "text": "This agent uses AI. Please verify important information."
        }
      }
    ]
  },
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": [
    "*.ngrok-free.app",
    "*.devtunnels.ms"
  ]
}

