    "Theme": "dark",
    "PrimaryColor": "#ffffff",
    "SecondaryColor": "#34e29a",
    "BackgroundColor": "#08130d",
    "NavbarColor": "#0c2018",
    "TextColor": "#ffffff",
    "AccentColor": "#008d5a",
    "SuccessColor": "#00b46f",
    "ErrorColor": "#e0556f",
    "LogoIcon": "bi-lightning-charge-fill",
    "WelcomeMessage": "Mejoramos la interacción con las y los usuarios de CFE y habilitamos capacidades de inteligencia artificial en la organización, evolucionando hacia una plataforma de automatización inteligente basada en agentes de IA.",
    "ChatWelcomeTitle": "Hola, soy tu Asistente Inteligente de CFE",
    "ChatWelcomeSubtitle": "Asisto, ejecuto y, progresivamente, automatizo procesos de mesa de servicio y operaciones de ciberseguridad.",
    "FooterText": "Comisión Federal de Electricidad · Hacia una plataforma de automatización inteligente basada en agentes de IA · Demo de propuesta",
    "Shape1ColorFrom": "#008d5a",
    "Shape1ColorTo": "#00d27f",
    "Shape2ColorFrom": "#ae8420",
    "Shape2ColorTo": "#e6c34d",
    "Shape3ColorFrom": "#701531",
    "Shape3ColorTo": "#b8466a",
    "ShapeAnimationSeconds": 16
  },
  "AzureOpenAI": {
    "Endpoint": "",
    "EndpointProject": "",
    "ApiKey": "",
    "ChatDeployment": "gpt-4o",
    "EmbeddingDeployment": "text-embedding-3-large"
  },
  "DevTunnel": {
    "Url": ""
  },
  "AzureSearch": {
    "Endpoint": "",
    "IndexName": "skill",
    "ApiKey": "",
    "LegalIndexName": "legal-documents",
    "SkillIndexName": "skill",
    "SemanticConfigName": "skill-semantic-config",
    "DefaultMaxResults": 15,
    "SkillIndex": {
      "IndexName": "skill",
      "SemanticConfigName": "skill-semantic-config"
    }
  },
  "AzureDocumentIntelligence": {
    "Endpoint": ""
  },
  "ConnectionStrings": {
    "SqlServer": "",
    "SqlServerMail": ""
  },
  "CosmosDB": {
    "ConnectionString": "",
    "DatabaseName": "af-webchat",
    "ContainerName": "sessions"
  },
  "BlobStorage": {
    "ConnectionString": "",
    "ContainerName": "documents"
  },
  "AzureStorage": {
    "AccountName": "",
    "ResourceGroup": "",
    "ContainerName": "skill-documents",
    "UseDefaultCredential": true,
    "ConnectionString": ""
  },
  "Azure": {
    "SubscriptionId": "",
    "ResourceGroup": "",
    "TenantId": ""
  },
  "AzureAI": {
    "ServicesKey": ""
  },
  "AzureSpeech": {
    "SubscriptionKey": "",
    "Region": "eastus2",
    "RecognitionLanguage": "es-MX",
    "SynthesisVoiceName": "es-MX-DaliaNeural"
  },
  "VoiceLive": {
    "Endpoint": "",
    "ApiKey": "",
    "Model": "gpt-4o-mini-realtime-preview",
    "Voice": "es-MX-DaliaNeural",
    "Instructions": "Eres un asistente de IA útil. Responde de forma natural y conversacional en español. Sé conciso pero atractivo."
  },
  "McpServer": {
    "Name": "GitHub MCP Server",
    "Command": "npx",
    "Arguments": "-y @modelcontextprotocol/server-github",
    "GitHubToken": ""
  },
  "BingSearch": {
    "ApiKey": ""
  },
  "AgentDefaults": {
    "MaxTokens": 4096,
    "Temperature": 0.7,
    "StreamingEnabled": true
  },
  "Session": {
    "Provider": "InMemory",
    "TimeoutMinutes": 60
  },
  "Workflows": {
    "MaxIterations": 10,
    "TimeoutSeconds": 300,
    "GroupChat": {
      "MaxTurns": 10
    }
  },
  "Orchestration": {
    "TimeoutSeconds": 1200,
    "GroupChatTimeoutSeconds": 1200
  },
  "Agents": {
    "WeatherAgent": {
      "Model": "gpt-4o-mini",
      "Temperature": 0.3,
      "MaxTokens": 1024
    },
    "LegalAdvisorAgent": {
      "Model": "gpt-4o",
      "Temperature": 0.1,
      "MaxTokens": 8192
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Tenant": {
    "ClientId": "cfe"
  },

  "TokenValidation": {
    "Enabled": false,
    "Audiences": [
      "{{YOUR_CLIENT_ID}}"
    ],
    "TenantId": "{{YOUR_TENANT_ID}}"
  },

  "AgentApplication": {
    "StartTypingTimer": false,
    "RemoveRecipientMention": true,
    "NormalizeMentions": true
  },

  "Connections": {
    "ServiceConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "AuthorityEndpoint": "https://login.microsoftonline.com/{{YOUR_TENANT_ID}}",
        "ClientId": "{{YOUR_CLIENT_ID}}",
        "ClientSecret": "{{YOUR_CLIENT_SECRET}}",
        "Scopes": [
          "https://api.botframework.com/.default"
        ]
      }
    }
  },
  "ConnectionsMap": [
    {
      "ServiceUrl": "*",
      "Connection": "ServiceConnection"
    }
  ]
}
