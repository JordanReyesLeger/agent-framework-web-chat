# =============================================================================
# Plantilla de variables de entorno para el workshop
# -----------------------------------------------------------------------------
# 1. Copia este archivo a `.env` (el .env real está gitignored)
# 2. Rellena los valores con tu Azure OpenAI
# 3. Los notebooks lo cargarán automáticamente vía python-dotenv
# =============================================================================

# Endpoint de tu recurso Azure OpenAI (sin el sufijo /openai)
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/

# Nombre del DEPLOYMENT (no del modelo) — ej: "gpt-4o", "gpt-4o-mini", etc.
AZURE_OPENAI_MODEL=gpt-4o

# Versión del API (opcional — por defecto 2024-10-21)
AZURE_OPENAI_API_VERSION=2024-10-21

# -----------------------------------------------------------------------------
# Autenticación: ELIGE UNA de las 2 opciones
# -----------------------------------------------------------------------------

# Opción A (recomendada) — Azure CLI Credential
# No definas AZURE_OPENAI_API_KEY. El helper usará `AzureCliCredential` automáticamente.
# Requisito: ejecuta `az login` antes de abrir los notebooks.
# Es el mismo patrón que usa el proyecto 02-AFWebChat.

# Opción B — API key (más simple si no tienes acceso `az login`)
# Descomenta la siguiente línea y pon tu API key real:
# AZURE_OPENAI_API_KEY=tu-api-key-aqui
