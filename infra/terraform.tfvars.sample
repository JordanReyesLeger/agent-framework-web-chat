# ─────────────────────────────────────────────
# terraform.tfvars.sample
# Copy this file to terraform.tfvars and fill in your values.
#   Copy-Item terraform.tfvars.sample terraform.tfvars
# ─────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────
subscription_id  = "00000000-0000-0000-0000-000000000000"  # Your Azure Subscription ID

# ── OPTIONAL – Override defaults ─────────────
# location         = "eastus2"
# environment_name = "dev"
# project_name     = "afweb"

# ── App Service (Linux Web App, .NET 9) ──────
# Web App is hosted in westus2 because the MCAPS subscription has no
# App Service VM quota elsewhere. After `terraform apply`, deploy your
# app with: az webapp deploy --src-path publish.zip --type zip ...
# app_service_sku      = "S2"          # Recommended baseline for 50+ users
# app_service_location = "westus2"

# ── OpenAI Models ────────────────────────────
# openai_chat_model_name     = "gpt-4o"
# openai_chat_model_version  = "2024-11-20"
# openai_chat_capacity       = 30
# openai_embedding_model_name    = "text-embedding-3-large"
# openai_embedding_model_version = "1"
# openai_embedding_capacity      = 30

# ── Optional Features (all enabled by default) ─
# enable_ai_search   = true
# ai_search_sku      = "standard"      # Better throughput, indexing, and latency
# ai_search_location = "eastus"     # eastus2 sometimes capacity-exhausted
# enable_cosmos_db   = true
# cosmos_sessions_autoscale_max_throughput = 4000  # Autoscale range: 400–4,000 RU/s
# enable_speech      = true
# enable_voicelive   = true         # Optional AI Foundry account for VoiceLive realtime
# enable_bot_service = true

# ── VoiceLive realtime (optional) ────────────
# voicelive_sku            = "S0"
# voicelive_location       = "eastus2"
# voicelive_model_name     = "gpt-realtime-mini"
# voicelive_model_version  = "2025-10-06"
# voicelive_model_capacity = 1
# voicelive_pro_model_name     = "gpt-realtime"
# voicelive_pro_model_version  = "2025-08-28"
# voicelive_pro_model_capacity = 1

# ── Disabled by default ──────────────────────
# enable_sql_database = false   # Blocked by MCAPS deny policy in many subs
# enable_bing_search  = false   # Bing Search APIs retired (2025)

# ── SQL (only if enable_sql_database = true) ─
# Set via TF_VAR_sql_admin_password env var (recommended) or here.
# sql_admin_login    = "sqladmin"
# sql_admin_password = "CHANGE-ME-strong-password-123!"
